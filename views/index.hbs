        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [{
                "@type": "Question",
                "name": "Is the Earth 6000 years old?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "No. The Earth is 4.54 billion years old and the universe is 13.8 billion years old. This is established through radiometric dating, stellar physics, and centuries of scientific discovery."
                }
            }]
        }
        </script>
